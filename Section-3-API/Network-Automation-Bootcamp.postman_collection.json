    { "key": "device_role_name", "value": "Network Device", "type": "string" },
    { "key": "site_name", "value": "Arena Stadium", "type": "string" },
    { "key": "device_type_model", "value": "C9200-48P", "type": "string" },
    { "key": "new_device_name", "value": "Postman-Test-Switch", "type": "string" },
