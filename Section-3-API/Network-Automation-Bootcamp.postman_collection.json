    { "key": "site_id", "value": "", "type": "string" },
    { "key": "device_type_id", "value": "", "type": "string" },
    { "key": "asn", "value": "13335", "type": "string" },
    { "key": "ip", "value": "1.1.1.1", "type": "string" },
    { "key": "prefix", "value": "1.1.1.0/24", "type": "string" }
  ]
}
